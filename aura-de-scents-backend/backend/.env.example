PORT=4000

# --- Supabase Postgres ---
# Project Settings → Database → Connection string → URI (use the "Transaction"
# pooler string on port 6543 if you're on Render's free tier / low connection limits,
# or the direct connection on 5432 otherwise). Keep the password URL-encoded.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# --- Supabase Storage (for product images) ---
# Project Settings → API → Project URL / service_role key.
# NEVER expose the service_role key to the frontend — server-side only.
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=change_this_to_your_service_role_key
SUPABASE_BUCKET=product-images

# Secret used to sign admin JWTs. Generate a real random string in production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string

# Admin login (used only to seed the first admin account on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Comma-separated list of origins allowed to call this API
# (your deployed frontend URL, e.g. Netlify/GitHub Pages — not just localhost)
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
